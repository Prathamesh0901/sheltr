{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "PORT", "SHELTR_SERVER_URL", "NODE_ENV", "BETTER_AUTH_SECRET", "BETTER_AUTH_URL"],
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    }
  }
}